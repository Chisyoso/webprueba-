// ─── ESP32 HTTP ───────────────────────────────────────────────
async function espSend(nativeCmd) {
  if(!S.esp.connected) {
    logWarn('ESP32 no conectado. Simulando localmente.');
    return null;
  }
  const url = `http://${S.esp.ip}:${S.esp.port}/cmd?c=${encodeURIComponent(nativeCmd)}`;
  const t0 = Date.now();
  try {
    const r = await fetch(url, { method:'GET', signal: AbortSignal.timeout(3000) });
    S.esp.ping = Date.now() - t0;
    S.esp.cmdsSent++;
    const j = await r.json();
    updateEspUI();
    return j;
  } catch(e) {
    S.esp.ping = null;
    logEsp('Error: ' + e.message);
    updateEspUI();
    return null;
  }
}

async function espConnect() {
  const ip   = document.getElementById('esp-ip-input').value.trim();
  const port = parseInt(document.getElementById('esp-port-input').value) || 80;
  await doConnect(ip, port);
}

async function doConnect(ip, port) {
  if(!ip) { logErr('Ingresa la IP del ESP32'); return; }
  S.esp.ip = ip; S.esp.port = port;
  document.getElementById('esp-dot').className = 'esp-dot connecting';
  document.getElementById('esp-label').textContent = 'Conectando...';
  logInfo(`Conectando a ESP32 en ${ip}:${port}...`);

  const url = `http://${ip}:${port}/ping`;
  const t0 = Date.now();
  try {
    const r = await fetch(url, { signal: AbortSignal.timeout(4000) });
    S.esp.ping = Date.now() - t0;
    S.esp.connected = true;
    logEsp(`Conectado! Latencia: ${S.esp.ping}ms`);
    log('✔ ESP32 listo', 'l-ok');
  } catch(e) {
    // Intento fallback con /cmd?c=ping
    try {
      const r2 = await fetch(`http://${ip}:${port}/cmd?c=ping`, { signal: AbortSignal.timeout(3000) });
      S.esp.ping = Date.now() - t0;
      S.esp.connected = true;
      logEsp(`Conectado! Latencia: ${S.esp.ping}ms`);
    } catch(e2) {
      S.esp.connected = false;
      logErr(`No se pudo conectar a ${ip}:${port} — ${e2.message}`);
      logWarn('Continuando en modo simulación local.');
    }
  }
  updateUI();
  closeConnectModal();
}

function espDisconnect() {
  S.esp.connected = false;
  S.esp.ping = null;
  logWarn('ESP32 desconectado.');
