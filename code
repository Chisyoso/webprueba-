// ─── PARSER DE SINTAXIS $comando(args) ───────────────────────
function parseTimbito(raw) {
  // Devuelve { name, args[] } o null
  const s = raw.trim();
  if(!s.startsWith('$')) return null;

  // Encuentra el primer (
  const pi = s.indexOf('(');
  if(pi === -1) {
    // $comando sin paréntesis → nombre solo
    return { name: s.slice(1), args: [] };
  }

  const name = s.slice(1, pi).trim();
  // Extrae contenido entre paréntesis (maneja anidación)
  let depth = 0, start = pi, end = -1;
  for(let i = pi; i < s.length; i++) {
    if(s[i]==='(') depth++;
    if(s[i]===')') { depth--; if(depth===0){ end=i; break; } }
  }

  const inner = end > -1 ? s.slice(pi+1, end) : s.slice(pi+1);
  const args = splitArgs(inner);
  return { name, args };
}

function splitArgs(s) {
  // Split por comas respetando paréntesis y comillas
  const args = [];
  let cur = '', depth = 0, inQ = false, qChar = '';
  for(let i = 0; i < s.length; i++) {
    const c = s[i];
    if(inQ) { cur+=c; if(c===qChar) inQ=false; continue; }
    if(c==='"'||c==="'") { inQ=true; qChar=c; cur+=c; continue; }
    if(c==='(') { depth++; cur+=c; continue; }
    if(c===')') { depth--; cur+=c; continue; }
    if(c===',' && depth===0) { args.push(cur.trim()); cur=''; continue; }
    cur += c;
  }
  if(cur.trim()) args.push(cur.trim());
  return args;
}

// ─── RESOLVE / EVAL ──────────────────────────────────────────
function resolveArg(a) {
  // Quita comillas
  const s = a.trim();
  if((s.startsWith('"')&&s.endsWith('"'))||(s.startsWith("'")&&s.endsWith("'")))
    return s.slice(1,-1);
  // Si es $variable.leer(x)
  if(s.startsWith('$')) {
    const p = parseTimbito(s);
    if(p && (p.name==='variable.leer'||p.name==='var.leer')) {
      const v = S.vars[p.args[0]];
      return v ? v.value : 0;
    }
  }
  // Si tiene operadores
  if(/[+\-*/%]/.test(s)) {
    try {
      // reemplaza $variable.leer(x)
      let expr = s.replace(/\$variable\.leer\((\w+)\)/g, (_,n) => {
        const v = S.vars[n]; return v ? v.value : 0;
      });
      return Function('"use strict";return (' + expr + ')')();
    } catch(e) {}
  }
  // Número
  if(!isNaN(s) && s !== '') return Number(s);
  return s;
}

function evalCond(expr) {
  let s = String(expr);
  s = s.replace(/\$variable\.leer\((\w+)\)/g, (_,n) => {
    const v = S.vars[n]; return v !== undefined ? v.value : 0;
  });
  try {
    return !!Function('"use strict";return (' + s + ')')();
  } catch(e) {
    throw new Error('Condición inválida: ' + expr);
  }
}

// ─── DELAY ───────────────────────────────────────────────────
const wait = ms => new Promise(r => setTimeout(r, ms));

// ─── EJECUTAR COMANDO ÚNICO ───────────────────────────────────
async function execCmd(raw, loopRef) {
  raw = raw.trim();
  if(!raw || raw.startsWith('//')) return;

  // Soporte bloques multilínea sin $ (para scripts)
  if(!raw.startsWith('$')) {
    // puede ser if/while/loop bloque inline dentro de script
    logWarn('Usa $comando(args) — ' + raw.slice(0,30));
    return;
  }

  const p = parseTimbito(raw);
  if(!p) { logErr('Sintaxis inválida: ' + raw); return; }
  const { name, args } = p;

  dbg({ cmd: name, args: args.join(', ') });

  // ══ VARIABLES ══
  if(name === 'variable.crear') {
    const vname = args[0], type = args[1] || 'number';
    if(!vname) { logErr('$variable.crear(nombre)'); return; }
    if(S.vars[vname]) { logWarn(`Variable '${vname}' ya existe`); return; }
    S.vars[vname] = { type, value: type==='string'?'':0 };
    log(`✔ var ${vname} [${type}] creada`);
    updateUI();
    return;
  }

  if(name === 'variable.editar' || name === 'variable.edit') {
    const vname = args[0];
    if(!vname) { logErr('$variable.editar(nombre, valor)'); return; }
    if(!S.vars[vname]) { logErr(`Variable '${vname}' no existe`); return; }
    const raw2 = args.slice(1).join(',');
    let val;
    try { val = resolveArg(raw2); } catch(e) { val = raw2; }
    S.vars[vname].value = val;
    dbg({ var: vname, '=': String(val) });
    updateUI();
    return;
  }

  if(name === 'variable.leer' || name === 'var.leer') {
    const vname = args[0];
    if(!S.vars[vname]) { logErr(`Variable '${vname}' no existe`); return; }
    logInfo(`${vname} = ${S.vars[vname].value}`);
    return;
  }

  if(name === 'variable.borrar' || name === 'variable.delete') {
    const vname = args[0];
    delete S.vars[vname];
    log(`✔ variable '${vname}' eliminada`);
    updateUI();
    return;
  }

  if(name === 'variables.listar') {
    if(Object.keys(S.vars).length===0) { logInfo('Sin variables'); return; }
    Object.entries(S.vars).forEach(([k,v]) => logInfo(`${k} [${v.type}] = ${v.value}`));
    return;
  }

  // ══ PINES ══
  if(name === 'pin.salida' || name === 'pin.crear.salida') {
    const num = String(resolveArg(args[0]));
    S.pins[num] = { mode:'OUTPUT', value:0 };
    log(`✔ pin ${num} [OUTPUT] creado`);
    await espSend(`PIN_OUT:${num}`);
    updateUI();
    return;
  }

  if(name === 'pin.entrada' || name === 'pin.crear.entrada') {
    const num = String(resolveArg(args[0]));
    S.pins[num] = { mode:'INPUT', value:0 };
    log(`✔ pin ${num} [INPUT] creado`);
    await espSend(`PIN_IN:${num}`);
    updateUI();
    return;
  }

  if(name === 'pin.escribir') {
    const num = String(resolveArg(args[0]));
    const val = resolveArg(args[1]);
    if(!S.pins[num]) S.pins[num] = { mode:'OUTPUT', value:0 };
    S.pins[num].value = val;
    dbg({ pin: num, val: String(val) });
    const res = await espSend(`PIN_WRITE:${num}:${val}`);
    if(res) logEsp(`pin ${num} ← ${val}`);
    updateUI();
    return;
  }

  if(name === 'pin.leer') {
    const num = String(resolveArg(args[0]));
    const res = await espSend(`PIN_READ:${num}`);
    if(res && res.val !== undefined) {
      S.pins[num] = S.pins[num] || { mode:'INPUT', value:0 };
      S.pins[num].value = res.val;
      logInfo(`pin ${num} = ${res.val}`);
      updateUI();
    } else {
      const v = S.pins[num]?.value ?? 0;
      logInfo(`pin ${num} = ${v} (local)`);
    }
    return;
  }

  // ══ LOOPS ══
  if(name === 'loop.init') {
    const lname = args[0];
    if(!lname) { logErr('$loop.init(nombre)'); return; }
    startLoop(lname);
    return;
  }

  if(name === 'loop.stop') {
    const lname = args[0];
    if(!lname) { logErr('$loop.stop(nombre)'); return; }
    stopLoop(lname);
    return;
  }

  // ══ DELAY ══
  if(name === 'delay') {
    const ms = resolveArg(args[0]);
    await wait(Number(ms));
    return;
  }

  // ══ PRINT ══
  if(name === 'print') {
    const val = args.map(a => resolveArg(a)).join(' ');
    logPrint('📤 ' + val);
    return;
  }

  // ══ ARCHIVO ══
  if(name === 'archivo.crear') {
    const fname = args[0];
    if(!fname) { logErr('$archivo.crear(nombre)'); return; }
    S.files[fname] = S.files[fname] || { content:'' };
    log(`✔ archivo '${fname}' creado`);
    return;
  }

  if(name === 'archivo.abrir') {
    const fname = args[0];
    if(!fname) { logErr('$archivo.abrir(nombre)'); return; }
    openEditor(fname);
    return;
  }

  if(name === 'archivo.ejecutar') {
    const fname = args[0];
    const f = S.files[fname];
    if(!f) { logErr(`Archivo '${fname}' no existe`); return; }
    log(`▶ ejecutando '${fname}'...`, 'l-info');
    await runScript(f.content);
    return;
  }

  if(name === 'archivo.borrar' || name === 'archivo.delete') {
    delete S.files[args[0]];
    log(`✔ archivo eliminado`);
    return;
  }

  // ══ FUNC ══
  if(name === 'func.llamar' || name === 'func.call') {
    const fname = args[0];
    const fn = S.funcs[fname];
    if(!fn) { logErr(`Función '${fname}' no existe`); return; }
    for(const s of fn) await execStep(s, loopRef);
    return;
  }

  // ══ DEBUG ══
  if(name === 'debug.on')    { S.debug=true;  logInfo('Debugger ON'); openDebug(); return; }
  if(name === 'debug.off')   { S.debug=false; logInfo('Debugger OFF'); return; }
  if(name === 'debug.clear') { dbgEl.innerHTML=''; return; }

  // ══ SISTEMA ══
  if(name === 'clear' || name === 'cls') { outEl.innerHTML=''; return; }

  if(name === 'reset') {
    Object.values(S.loops).forEach(l => l.running=false);
    Object.assign(S, { vars:{}, pins:{}, loops:{}, funcs:{}, files:{} });
    updateUI();
    logWarn('Sistema reseteado.');
    return;
  }

  if(name === 'help') {
    showHelp();
    return;
  }

  // ══ ESP32 directo ══
  if(name === 'esp.send') {
    const cmdRaw = args[0];
    if(!cmdRaw) { logErr('$esp.send(comando)'); return; }
    const res = await espSend(cmdRaw);
    logEsp(res ? JSON.stringify(res) : 'sin respuesta');
    return;
  }

  if(name === 'esp.ping') {
    const t0 = Date.now();
    const res = await espSend('ping');
    logEsp(res ? `pong! ${Date.now()-t0}ms` : 'sin respuesta');
    return;
  }

  logErr(`Comando desconocido: $${name}`);
}

// ─── AST STEP EXECUTOR ───────────────────────────────────────
async function execStep(step, loopRef) {
  if(loopRef && !loopRef.running) throw new Error('__STOPPED__');

  if(step.type === 'cmd') {
    dbg({ linea: step.cmd });
    await execCmd(step.cmd, loopRef);
    return;
  }

  if(step.type === 'if') {
    const cond = evalCond(step.cond);
    dbg({ if: step.cond, result: cond });
    const block = cond ? step.then : step.else;
    for(const s of block) await execStep(s, loopRef);
    return;
  }

  if(step.type === 'while') {
    let n = 0;
    while(true) {
      if(loopRef && !loopRef.running) break;
      const cond = evalCond(step.cond);
      dbg({ while: step.cond, result: cond });
      if(!cond) break;
      for(const s of step.body) await execStep(s, loopRef);
      if(++n > 100000) { logErr('while: demasiadas iteraciones'); break; }
    }
    return;
  }
}

// ─── SCRIPT PARSER (MULTILINEA) ──────────────────────────────
// Parsea un script completo con loops, ifs, whiles, funcs
function parseScript(code) {
  const lines = code.split('\n')
    .map(l => l.trim())
    .filter(l => l && !l.startsWith('//'));
  let idx = 0;

  function parseBlock(stopWhen) {
    const body = [];
    while(idx < lines.length) {
      const line = lines[idx];
      if(stopWhen && stopWhen(line)) break;

      // IF
      if(line.startsWith('$if(') || line.startsWith('$if (')) {
        const cond = extractInner(line);
        idx++;
        const thenB = parseBlock(l => l==='$else' || l==='$if.final' || l==='$endif');
        let elseB = [];
        if(idx<lines.length && (lines[idx]==='$else' || lines[idx].startsWith('$else('))) {
          idx++;
          elseB = parseBlock(l => l==='$if.final' || l==='$endif');
        }
        if(idx<lines.length) idx++;
        body.push({ type:'if', cond, then:thenB, else:elseB });
        continue;
      }

      // WHILE
      if(line.startsWith('$while(')) {
        const cond = extractInner(line);
        idx++;
        const wb = parseBlock(l => l==='$endwhile' || l==='$while.final');
        if(idx<lines.length) idx++;
        body.push({ type:'while', cond, body:wb });
        continue;
      }

      body.push({ type:'cmd', cmd:line });
      idx++;
    }
    return body;
  }

  return parseBlock(null);
}

function extractInner(line) {
  const pi = line.indexOf('(');
  const pe = line.lastIndexOf(')');
  if(pi<0) return '';
  return pe>pi ? line.slice(pi+1, pe) : line.slice(pi+1);
}

// ─── SCRIPT RUNNER ────────────────────────────────────────────
async function runScript(code) {
  const lines = code.split('\n').map(l=>l.trim()).filter(l=>l&&!l.startsWith('//'));
  let i = 0;

  while(i < lines.length) {
    const line = lines[i];

    // LOOP DEFINITION: $loop.nombre( ... )
    // Formato: $loop.blink(
    //   $pin.escribir(2,1)
    //   $delay(500)
    // )
    const loopDefMatch = line.match(/^\$loop\.(\w+)\($/);
    if(loopDefMatch) {
      const lname = loopDefMatch[1];
      if(lname !== 'init' && lname !== 'stop' && lname !== 'final') {
        i++;
        const rawLines = [];
        let depth = 0;
        while(i < lines.length) {
          const l = lines[i];
          if(l === ')' && depth === 0) { i++; break; }
          if(l.endsWith('(')) depth++;
          if(l === ')') depth--;
          rawLines.push(l);
          i++;
        }
        const ast = parseScript(rawLines.join('\n'));
        S.loops[lname] = { body: ast, rawLines, running: false };
        log(`✔ loop '${lname}' definido (${rawLines.length} líneas)`, 'l-ok');
        updateUI();
        continue;
      }
    }

    // FUNC DEFINITION: $func.nombre(
    const funcDefMatch = line.match(/^\$func\.(\w+)\($/);
    if(funcDefMatch) {
      const fname = funcDefMatch[1];
      if(fname !== 'call' && fname !== 'llamar') {
        i++;
        const funcLines = [];
        while(i < lines.length && lines[i] !== ')') {
          funcLines.push(lines[i]);
          i++;
        }
        if(i < lines.length) i++;
        S.funcs[fname] = parseScript(funcLines.join('\n'));
        log(`✔ función '${fname}' definida`, 'l-ok');
        continue;
      }
    }

    // IF BLOCK
    if(line.startsWith('$if(')) {
      const blockLines = [line];
      i++;
      let depth = 0;
      while(i < lines.length) {
        const l = lines[i];
        if(l.startsWith('$if(')) depth++;
        if(l === '$if.final' || l === '$endif') {
          blockLines.push(l); i++;
          if(depth === 0) break;
          depth--;
          continue;
        }
        blockLines.push(l);
        i++;
      }
      const ast = parseScript(blockLines.join('\n'));
      for(const s of ast) await execStep(s, null);
      continue;
    }

    // WHILE BLOCK
    if(line.startsWith('$while(')) {
      const blockLines = [line];
      i++;
      while(i < lines.length && lines[i] !== '$endwhile' && lines[i] !== '$while.final') {
        blockLines.push(lines[i]);
        i++;
      }
      blockLines.push('$endwhile');
      if(i < lines.length) i++;
      const ast = parseScript(blockLines.join('\n'));
      for(const s of ast) await execStep(s, null);
      continue;
    }

    // COMANDO NORMAL
    await execCmd(line, null);
    i++;
  }

  updateUI();
}

// ─── LOOP ENGINE ─────────────────────────────────────────────
function startLoop(name) {
  const lp = S.loops[name];
  if(!lp) { logErr(`Loop '${name}' no definido. Ábrelo en el editor.`); return; }
  if(lp.running) { logWarn(`Loop '${name}' ya corre`); return; }
  lp.running = true;
  log(`▶ loop '${name}' iniciado`, 'l-ok');
  updateUI();

  (async () => {
    try {
      while(lp.running) {
        for(const step of lp.body) {
          if(!lp.running) break;
          await execStep(step, lp);
        }
      }
    } catch(e) {
      if(e.message !== '__STOPPED__') logErr(`Loop '${name}': ${e.message}`);
    }
    lp.running = false;
    logWarn(`⏹ loop '${name}' parado`);
    updateUI();
  })();
}

function stopLoop(name) {
  if(!S.loops[name]) { logErr(`Loop '${name}' no existe`); return; }
  S.loops[name].running = false;
  logWarn(`⏹ loop '${name}' detenido`);
  updateUI();
}

function togglePin(num) {
  if(!S.pins[num] || S.pins[num].mode !== 'OUTPUT') return;
  const newVal = S.pins[num].value > 0 ? 0 : 1;
  execCmd(`$pin.escribir(${num}, ${newVal})`);
}

// ─── EDITOR ──────────────────────────────────────────────────
let currentFile = null;

function openEditor(name) {
  if(!S.files[name]) S.files[name] = { content: '' };
  currentFile = name;
  document.getElementById('editor-fname').textContent = `📄 ${name}`;
  document.getElementById('editor-area').value = S.files[name].content;
  document.getElementById('editor-overlay').classList.add('open');
  setTimeout(()=>document.getElementById('editor-area').focus(), 100);
}

function editorSave() {
  if(!currentFile) return;
  S.files[currentFile].content = document.getElementById('editor-area').value;
  log(`✔ '${currentFile}' guardado`, 'l-ok');
  document.getElementById('editor-bar').textContent = '✔ Guardado — ' + new Date().toLocaleTimeString();
  updateUI();
}

async function editorRun() {
  if(!currentFile) return;
  S.files[currentFile].content = document.getElementById('editor-area').value;
  editorClose();
  log(`▶ ejecutando '${currentFile}'...`, 'l-info');
  await runScript(S.files[currentFile].content);
}

function editorClose() {
  document.getElementById('editor-overlay').classList.remove('open');
  document.getElementById('cmd-input').focus();
}

document.getElementById('editor-area').addEventListener('keydown', e => {
  if(e.ctrlKey && e.key==='s') { e.preventDefault(); editorSave(); }
  if(e.key==='Tab') {
    e.preventDefault();
    const t=e.target, s=t.selectionStart, en=t.selectionEnd;
    t.value = t.value.slice(0,s) + '  ' + t.value.slice(en);
    t.selectionStart = t.selectionEnd = s + 2;
  }
});

// ─── TERMINAL INPUT ───────────────────────────────────────────
const inp = document.getElementById('cmd-input');

async function sendCmd() {
  const raw = inp.value.trim();
  if(!raw) return;
  S.history.unshift(raw);
  S.histIdx = -1;
  inp.value = '';
  log(raw, 'l-cmd');
  await runScript(raw);
  updateUI();
}

inp.addEventListener('keydown', async e => {
  if(e.key === 'Enter') { e.preventDefault(); await sendCmd(); return; }
  if(e.key === 'ArrowUp') {
    e.preventDefault();
    if(S.histIdx < S.history.length-1) { S.histIdx++; inp.value=S.history[S.histIdx]; }
  }
  if(e.key === 'ArrowDown') {
    e.preventDefault();
    if(S.histIdx > 0) { S.histIdx--; inp.value=S.history[S.histIdx]; }
    else { S.histIdx=-1; inp.value=''; }
  }
});

function fillCmd(cmd) {
  inp.value = cmd;
  inp.focus();
  // posiciona cursor dentro de ()
  const pi = cmd.indexOf('(');
  if(pi > -1) setTimeout(()=>inp.setSelectionRange(pi+1, inp.value.indexOf(')')<0?cmd.length:inp.value.indexOf(')')), 0);
}

