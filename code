<!DOCTYPE html>

<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>timbitoOS v4</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;500;600&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --bg0:    #030507;
  --bg1:    #070a0f;
  --bg2:    #0c1018;
  --bg3:    #111722;
  --border: #18202e;
  --border2:#1f2c3f;
  --acc:    #00e5ff;
  --acc2:   #00ff9f;
  --acc3:   #ff3d6b;
  --acc4:   #ffaa00;
  --acc5:   #bf5af2;
  --text:   #b0c4d8;
  --dim:    #3a4a5e;
  --dim2:   #253040;
  --font:   'Fira Code', monospace;
  --head:   'Orbitron', sans-serif;
  --safe-bottom: env(safe-area-inset-bottom, 0px);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

html, body {
height: 100%; width: 100%;
background: var(–bg0);
color: var(–text);
font-family: var(–font);
overflow: hidden;
touch-action: manipulation;
}

/* ── NOISE OVERLAY ── */
body::before {
content: ‘’;
position: fixed; inset: 0;
background-image: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 256 256’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘n’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.9’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23n)’ opacity=‘0.04’/%3E%3C/svg%3E”);
pointer-events: none; z-index: 9998; opacity: .6;
}

/* ── SCANLINES ── */
body::after {
content: ‘’;
position: fixed; inset: 0;
background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0,0,0,.06) 3px, rgba(0,0,0,.06) 4px);
pointer-events: none; z-index: 9997;
}

/* ══════════════════ LAYOUT ══════════════════ */
#app {
display: flex;
flex-direction: column;
height: 100%;
height: 100dvh;
}

/* ── TOPBAR ── */
#topbar {
flex: 0 0 auto;
display: flex;
align-items: center;
justify-content: space-between;
padding: 10px 14px 8px;
background: var(–bg1);
border-bottom: 1px solid var(–border);
gap: 10px;
}

#logo {
font-family: var(–head);
font-size: 15px;
font-weight: 900;
letter-spacing: 3px;
color: var(–acc);
text-shadow: 0 0 16px rgba(0,229,255,.35), 0 0 40px rgba(0,229,255,.1);
white-space: nowrap;
}
#logo sub { font-size: 9px; color: var(–dim); letter-spacing: 1px; }

#esp-status {
display: flex;
align-items: center;
gap: 8px;
flex: 1;
justify-content: flex-end;
}
.esp-dot {
width: 8px; height: 8px;
border-radius: 50%;
background: var(–dim);
transition: background .3s, box-shadow .3s;
}
.esp-dot.connected { background: var(–acc2); box-shadow: 0 0 8px var(–acc2), 0 0 20px rgba(0,255,159,.2); animation: pulse-dot 2s infinite; }
.esp-dot.error     { background: var(–acc3); box-shadow: 0 0 8px var(–acc3); }
.esp-dot.connecting { background: var(–acc4); box-shadow: 0 0 8px var(–acc4); animation: blink .6s infinite; }
@keyframes pulse-dot { 0%,100%{opacity:1} 50%{opacity:.5} }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.2} }

#esp-label { font-size: 10px; color: var(–dim); letter-spacing: .5px; }
#esp-label.ok { color: var(–acc2); }
#esp-label.err { color: var(–acc3); }

#btn-connect {
background: var(–bg3);
border: 1px solid var(–border2);
color: var(–dim);
font-family: var(–font);
font-size: 10px;
padding: 5px 10px;
border-radius: 6px;
cursor: pointer;
transition: .2s;
white-space: nowrap;
}
#btn-connect:active { opacity: .7; }
#btn-connect.connected { border-color: var(–acc3); color: var(–acc3); }

/* ── TABS ── */
#tabs {
flex: 0 0 auto;
display: flex;
background: var(–bg1);
border-bottom: 1px solid var(–border);
overflow-x: auto;
scrollbar-width: none;
}
#tabs::-webkit-scrollbar { display: none; }
.tab {
flex: 0 0 auto;
padding: 9px 16px;
font-family: var(–font);
font-size: 10px;
letter-spacing: 1px;
color: var(–dim);
border-bottom: 2px solid transparent;
cursor: pointer;
transition: .15s;
white-space: nowrap;
user-select: none;
}
.tab.active { color: var(–acc); border-bottom-color: var(–acc); }
.tab:active { opacity: .7; }

/* ── VIEWS ── */
#views { flex: 1; overflow: hidden; display: flex; flex-direction: column; }
.view { display: none; flex: 1; flex-direction: column; overflow: hidden; }
.view.active { display: flex; }

/* ════════ TERMINAL VIEW ════════ */
#terminal-view { background: var(–bg0); }

#output {
flex: 1;
overflow-y: auto;
padding: 12px 14px 4px;
font-size: 12.5px;
line-height: 1.8;
overscroll-behavior: contain;
scrollbar-width: thin;
scrollbar-color: var(–border) transparent;
}
#output::-webkit-scrollbar { width: 3px; }
#output::-webkit-scrollbar-thumb { background: var(–border2); border-radius: 2px; }

.l-cmd   { color: rgba(255,255,255,.35); font-size: 11px; }
.l-ok    { color: var(–acc2); }
.l-err   { color: var(–acc3); }
.l-warn  { color: var(–acc4); }
.l-info  { color: var(–acc); }
.l-print { color: #e0eeff; }
.l-sys   { color: var(–dim); font-size: 11px; font-style: italic; }
.l-debug { color: var(–acc5); font-size: 11px; }
.l-esp   { color: var(–acc4); font-size: 11px; }
.l-sep   { border-top: 1px solid var(–border); margin: 4px 0; }

/* Highlight $ commands */
.l-cmd .hl { color: rgba(0,229,255,.5); }

/* Input area */
#input-wrap {
flex: 0 0 auto;
background: var(–bg1);
border-top: 1px solid var(–border);
}

/* Quick command shortcuts */
#quick-cmds {
display: flex;
gap: 6px;
padding: 8px 10px 4px;
overflow-x: auto;
scrollbar-width: none;
}
#quick-cmds::-webkit-scrollbar { display: none; }
.qcmd {
flex: 0 0 auto;
background: var(–bg2);
border: 1px solid var(–border2);
color: var(–acc);
font-family: var(–font);
font-size: 10px;
padding: 5px 10px;
border-radius: 20px;
cursor: pointer;
transition: .15s;
white-space: nowrap;
}
.qcmd:active { background: var(–bg3); border-color: var(–acc); }

#input-row {
display: flex;
align-items: center;
padding: 8px 10px;
padding-bottom: calc(8px + var(–safe-bottom));
gap: 8px;
}
#prompt {
color: var(–acc);
font-size: 15px;
user-select: none;
flex-shrink: 0;
}
#cmd-input {
flex: 1;
background: var(–bg2);
border: 1px solid var(–border2);
border-radius: 8px;
outline: none;
color: #e8f4ff;
font-family: var(–font);
font-size: 13px;
padding: 8px 12px;
caret-color: var(–acc);
transition: border-color .2s;
-webkit-appearance: none;
}
#cmd-input:focus { border-color: var(–acc); box-shadow: 0 0 0 2px rgba(0,229,255,.08); }
#cmd-input::placeholder { color: var(–dim); }

#btn-send {
background: var(–acc);
color: var(–bg0);
border: none;
border-radius: 8px;
width: 38px; height: 38px;
font-size: 16px;
cursor: pointer;
display: flex; align-items: center; justify-content: center;
flex-shrink: 0;
transition: .15s;
font-weight: 700;
}
#btn-send:active { opacity: .7; transform: scale(.95); }

/* ════════ VARIABLES VIEW ════════ */
#vars-view { background: var(–bg0); }

.view-header {
padding: 12px 14px 8px;
font-family: var(–head);
font-size: 11px;
letter-spacing: 2px;
color: var(–dim);
border-bottom: 1px solid var(–border);
display: flex;
align-items: center;
justify-content: space-between;
}
.view-header span { color: var(–acc); }

.list-wrap { flex: 1; overflow-y: auto; padding: 8px 0; scrollbar-width: thin; scrollbar-color: var(–border) transparent; }

.var-card {
margin: 6px 12px;
background: var(–bg2);
border: 1px solid var(–border);
border-radius: 10px;
padding: 12px 14px;
display: flex;
align-items: center;
gap: 12px;
transition: border-color .2s;
animation: slideIn .2s ease;
}
@keyframes slideIn { from { opacity:0; transform:translateY(6px) } to { opacity:1; transform:translateY(0) } }
.var-card:active { border-color: var(–acc); }
.var-type-badge {
background: var(–bg3);
border: 1px solid var(–border2);
border-radius: 5px;
padding: 2px 7px;
font-size: 9px;
color: var(–acc);
letter-spacing: 1px;
flex-shrink: 0;
}
.var-info { flex: 1; min-width: 0; }
.var-name { font-size: 13px; color: #e0eeff; font-weight: 500; }
.var-val  { font-size: 12px; color: var(–acc4); margin-top: 1px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.var-del  { color: var(–dim); font-size: 16px; padding: 4px; cursor: pointer; flex-shrink: 0; }
.var-del:active { color: var(–acc3); }

.empty-state {
display: flex; flex-direction: column; align-items: center; justify-content: center;
flex: 1; gap: 8px;
color: var(–dim); font-size: 12px;
}
.empty-icon { font-size: 32px; opacity: .3; }

/* ════════ PINES VIEW ════════ */
#pins-view { background: var(–bg0); }

.pin-grid {
flex: 1; overflow-y: auto;
display: grid;
grid-template-columns: 1fr 1fr;
gap: 10px;
padding: 10px 12px;
align-content: start;
}
.pin-card {
background: var(–bg2);
border: 1px solid var(–border);
border-radius: 12px;
padding: 14px 12px;
display: flex;
flex-direction: column;
align-items: center;
gap: 8px;
cursor: pointer;
transition: .2s;
animation: slideIn .2s;
}
.pin-card.on { border-color: var(–acc2); background: rgba(0,255,159,.04); }
.pin-card.on .pin-led { background: var(–acc2); box-shadow: 0 0 16px var(–acc2), 0 0 40px rgba(0,255,159,.2); }
.pin-led {
width: 28px; height: 28px;
border-radius: 50%;
background: var(–dim2);
border: 2px solid var(–border2);
transition: .25s;
}
.pin-num { font-size: 13px; font-weight: 600; color: var(–text); }
.pin-mode-badge {
font-size: 9px;
padding: 2px 8px;
border-radius: 10px;
border: 1px solid var(–border2);
color: var(–dim);
}
.pin-card.on .pin-mode-badge { border-color: var(–acc2); color: var(–acc2); }
.pin-val { font-size: 18px; font-weight: 700; font-family: var(–head); color: var(–dim); }
.pin-card.on .pin-val { color: var(–acc2); }

/* ════════ LOOPS VIEW ════════ */
#loops-view { background: var(–bg0); }

.loop-list-wrap { flex: 1; overflow-y: auto; padding: 8px 0; }

.loop-card {
margin: 6px 12px;
background: var(–bg2);
border: 1px solid var(–border);
border-radius: 10px;
overflow: hidden;
animation: slideIn .2s;
transition: border-color .2s;
}
.loop-card.running { border-color: var(–acc); }
.loop-header {
display: flex;
align-items: center;
padding: 12px 14px;
gap: 12px;
}
.loop-indicator {
width: 8px; height: 8px;
border-radius: 50%;
background: var(–dim);
flex-shrink: 0;
}
.loop-card.running .loop-indicator {
background: var(–acc);
box-shadow: 0 0 8px var(–acc);
animation: pulse-dot 1s infinite;
}
.loop-name { flex: 1; font-size: 13px; color: var(–text); font-weight: 500; }
.loop-lines { font-size: 10px; color: var(–dim); }
.loop-actions { display: flex; gap: 6px; }
.loop-btn-action {
background: var(–bg3);
border: 1px solid var(–border2);
color: var(–dim);
font-family: var(–font);
font-size: 10px;
padding: 5px 10px;
border-radius: 6px;
cursor: pointer;
transition: .15s;
}
.loop-btn-action.run  { border-color: var(–acc2); color: var(–acc2); }
.loop-btn-action.stop { border-color: var(–acc3); color: var(–acc3); }
.loop-btn-action:active { opacity: .7; }
.loop-body-preview {
padding: 0 14px 10px;
font-size: 10px;
color: var(–dim);
line-height: 1.7;
border-top: 1px solid var(–border);
padding-top: 8px;
}

/* ════════ ESP32 VIEW ════════ */
#esp-view { background: var(–bg0); }

.esp-config-wrap { flex: 1; overflow-y: auto; padding: 12px; }

.esp-card {
background: var(–bg2);
border: 1px solid var(–border);
border-radius: 12px;
padding: 14px;
margin-bottom: 10px;
}
.esp-card-title {
font-family: var(–head);
font-size: 10px;
color: var(–dim);
letter-spacing: 2px;
margin-bottom: 12px;
}

.esp-field { margin-bottom: 10px; }
.esp-label { font-size: 10px; color: var(–dim); margin-bottom: 5px; letter-spacing: .5px; }
.esp-input {
width: 100%;
background: var(–bg3);
border: 1px solid var(–border2);
border-radius: 8px;
color: #e0eeff;
font-family: var(–font);
font-size: 13px;
padding: 10px 12px;
outline: none;
-webkit-appearance: none;
transition: border-color .2s;
}
.esp-input:focus { border-color: var(–acc); }

.esp-action-btn {
width: 100%;
background: transparent;
border: 1px solid var(–acc2);
color: var(–acc2);
font-family: var(–font);
font-size: 12px;
padding: 12px;
border-radius: 8px;
cursor: pointer;
transition: .2s;
letter-spacing: 1px;
margin-top: 4px;
}
.esp-action-btn:active { background: rgba(0,255,159,.08); }
.esp-action-btn.danger { border-color: var(–acc3); color: var(–acc3); }
.esp-action-btn.danger:active { background: rgba(255,61,107,.08); }

.esp-status-card {
background: var(–bg2);
border: 1px solid var(–border);
border-radius: 12px;
padding: 14px;
margin-bottom: 10px;
}
.esp-stat-row {
display: flex;
justify-content: space-between;
align-items: center;
padding: 5px 0;
font-size: 11px;
border-bottom: 1px solid var(–border);
}
.esp-stat-row:last-child { border-bottom: none; }
.esp-stat-key { color: var(–dim); }
.esp-stat-val { color: var(–text); font-weight: 500; }
.esp-stat-val.ok  { color: var(–acc2); }
.esp-stat-val.err { color: var(–acc3); }

/* ════════ EDITOR OVERLAY ════════ */
#editor-overlay {
display: none;
position: fixed; inset: 0;
background: rgba(0,0,0,.85);
z-index: 500;
flex-direction: column;
backdrop-filter: blur(4px);
}
#editor-overlay.open { display: flex; }

#editor-topbar {
background: var(–bg1);
border-bottom: 1px solid var(–border2);
padding: 12px 14px;
display: flex;
align-items: center;
justify-content: space-between;
flex-shrink: 0;
}
#editor-fname {
font-family: var(–head);
font-size: 12px;
color: var(–acc);
letter-spacing: 1px;
}
#editor-btns { display: flex; gap: 8px; }
.ed-btn {
background: var(–bg3);
border: 1px solid var(–border2);
color: var(–text);
font-family: var(–font);
font-size: 11px;
padding: 7px 14px;
border-radius: 7px;
cursor: pointer;
transition: .15s;
}
.ed-btn.save { border-color: var(–acc2); color: var(–acc2); }
.ed-btn.run-ed { border-color: var(–acc4); color: var(–acc4); }
.ed-btn:active { opacity: .7; }

#editor-area {
flex: 1;
background: var(–bg0);
border: none;
outline: none;
resize: none;
color: #e0eeff;
font-family: var(–font);
font-size: 13px;
line-height: 1.8;
padding: 14px;
caret-color: var(–acc);
tab-size: 2;
-webkit-appearance: none;
}
#editor-bar {
background: var(–bg1);
border-top: 1px solid var(–border);
padding: 6px 14px;
font-size: 10px;
color: var(–dim);
flex-shrink: 0;
padding-bottom: calc(6px + var(–safe-bottom));
}

/* ════════ DEBUG OVERLAY ════════ */
#debug-overlay {
position: fixed;
bottom: 0; left: 0; right: 0;
background: rgba(7,10,15,.97);
border-top: 2px solid var(–acc5);
z-index: 400;
max-height: 45vh;
display: none;
flex-direction: column;
transform: translateY(100%);
transition: transform .3s ease;
}
#debug-overlay.open { display: flex; transform: translateY(0); }
#debug-topbar {
display: flex;
align-items: center;
justify-content: space-between;
padding: 10px 14px;
border-bottom: 1px solid var(–border);
flex-shrink: 0;
}
#debug-title { font-family: var(–head); font-size: 11px; color: var(–acc5); letter-spacing: 2px; }
#debug-close { color: var(–dim); font-size: 18px; cursor: pointer; padding: 2px 6px; }
#debug-content {
flex: 1;
overflow-y: auto;
padding: 10px 14px;
font-size: 11px;
line-height: 1.7;
scrollbar-width: thin;
scrollbar-color: var(–border) transparent;
}
.dbg-row { padding: 2px 0; border-bottom: 1px solid rgba(255,255,255,.04); }
.dbg-k { color: var(–acc5); }
.dbg-v { color: var(–text); }
.dbg-cond-t { color: var(–acc2); }
.dbg-cond-f { color: var(–acc3); }

/* ════════ CONNECT MODAL ════════ */
#connect-modal {
display: none;
position: fixed; inset: 0;
background: rgba(0,0,0,.8);
z-index: 600;
align-items: center;
justify-content: center;
backdrop-filter: blur(6px);
}
#connect-modal.open { display: flex; }
#connect-box {
background: var(–bg1);
border: 1px solid var(–border2);
border-radius: 16px;
padding: 20px;
width: min(90vw, 360px);
box-shadow: 0 0 40px rgba(0,229,255,.05);
}
#connect-title {
font-family: var(–head);
font-size: 13px;
color: var(–acc);
letter-spacing: 2px;
margin-bottom: 16px;
text-align: center;
}
.conn-field { margin-bottom: 12px; }
.conn-label { font-size: 10px; color: var(–dim); margin-bottom: 5px; letter-spacing: .5px; }
.conn-input {
width: 100%;
background: var(–bg3);
border: 1px solid var(–border2);
border-radius: 8px;
color: #e0eeff;
font-family: var(–font);
font-size: 13px;
padding: 10px 12px;
outline: none;
-webkit-appearance: none;
}
.conn-input:focus { border-color: var(–acc); }
.conn-btns { display: flex; gap: 8px; margin-top: 4px; }
.conn-btn {
flex: 1;
background: transparent;
border: 1px solid var(–border2);
color: var(–text);
font-family: var(–font);
font-size: 11px;
padding: 10px;
border-radius: 8px;
cursor: pointer;
transition: .15s;
}
.conn-btn.primary { border-color: var(–acc); color: var(–acc); }
.conn-btn:active { opacity: .7; }

/* Utility */
.sep-line { height: 1px; background: var(–border); margin: 4px 0; }

/* FAB debug */
#fab-debug {
position: fixed;
bottom: calc(16px + var(–safe-bottom));
right: 16px;
background: var(–bg2);
border: 1px solid var(–acc5);
color: var(–acc5);
width: 40px; height: 40px;
border-radius: 50%;
display: flex; align-items: center; justify-content: center;
font-size: 16px;
cursor: pointer;
z-index: 300;
box-shadow: 0 0 12px rgba(191,90,242,.2);
transition: .15s;
display: none;
}
#fab-debug:active { transform: scale(.92); }
</style>

